<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.StudentsDetailPage"
             Title="Student Details">
    <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">
        <Label x:Name="NameLabel" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <Label x:Name="FactLabel" FontSize="16" HorizontalOptions="Center" TextColor="Gray" />
    </VerticalStackLayout>
</ContentPage>